# Minions / Pi runtime configuration
# Copy to .env and fill in values as needed.

# Minions autonomous execution mode
# Pi RPC is the intended autonomous runner path.
# Delivery remains simulated by default for safety.
MINIONS_EXECUTION_MODE=agent-runner
MINIONS_DELIVERY_MODE=simulated
MINIONS_DEFAULT_REPOSITORY_PATH=

# Pi RPC runner configuration
MINIONS_PI_COMMAND=pi
MINIONS_PI_PROVIDER=
MINIONS_PI_MODEL=
MINIONS_PI_SESSION_DIR=
MINIONS_PI_ARGS=
MINIONS_PI_DISABLE_RESOURCE_DISCOVERY=true
MINIONS_PI_ISOLATE_AGENT_DIR=true
MINIONS_PI_AGENT_DIR=
MINIONS_PI_SUBSCRIPTION_AGENT_DIR=
# Set to openai-chatgpt-subscription or openai-codex to enable in-app ChatGPT/Codex subscription auth reuse.
# Legacy alias codex is also accepted.
# MINIONS_PI_PROVIDER=openai-codex

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# OpenRouter
OPENROUTER_API_KEY=sk-or-...

# Firecrawl (used by pi-pi expert agents for web crawling)
FIRECRAWL_API_KEY=fc-...
